{
  "name": "advanced-antivirus",
  "version": "1.0.0",
  "description": "Comprehensive Desktop Antivirus for Multiple Malware Types",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "react-test": "react-scripts test",
    "react-eject": "react-scripts eject",
    "electron-start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-build": "npm run react-build && electron-builder",
    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron . --dev\"",
    "build": "npm run react-build && electron-builder --win --publish never",
    "start": "electron ."
  },
  "dependencies": {
    "axios": "^1.3.2",
    "chart.js": "^4.2.1",
    "electron-store": "^11.0.2",
    "ps-list": "^7.2.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "systeminformation": "^5.11.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "concurrently": "^7.6.0",
    "electron": "^23.3.13",
    "electron-builder": "^24.13.3",
    "electron-is-dev": "^2.0.0",
    "react-scripts": "^5.0.1",
    "wait-on": "^7.2.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.antivirus.app",
    "productName": "Advanced Antivirus",
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "malware-db.js",
      "detection-engine.js",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "certificateFile": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
